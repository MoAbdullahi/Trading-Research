// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0
// © ICT H4/M5 Best Setup Indicator — based on systematic backtesting research
// Best setup: H4 Bias | M5 Entry | OB Only | Confirm(MSS) | GO Sessions
// Results: 75% WR | PF 2.31 | Calmar 140 | +992R over 4 years

//@version=5
indicator("ICT H4 OB + M5 MSS [Best Setup]", overlay=true, max_boxes_count=10, max_lines_count=50, max_labels_count=50)

// ── INPUTS ────────────────────────────────────────────────────────────────────
htf           = input.timeframe("240", "HTF (4H) Timeframe")
swing_len     = input.int(15, "Swing Length (higher = fewer signals)", minval=5, maxval=50)
show_sessions = input.bool(true, "Show Kill Zone Shading")
show_ob_zones = input.bool(true, "Show Order Block Boxes")
show_bos      = input.bool(true, "Show BOS Labels")
show_entry    = input.bool(true, "Show Entry Signals")
show_sl_tp    = input.bool(true, "Show SL / TP Lines")
show_table    = input.bool(true, "Show Info Table")
bull_ob_col   = input.color(color.new(#00c853, 82), "Bullish OB Fill")
bear_ob_col   = input.color(color.new(#d50000, 82), "Bearish OB Fill")
long_col      = input.color(#00e676, "Long Signal Color")
short_col     = input.color(#ff1744, "Short Signal Color")

// ── SESSIONS ──────────────────────────────────────────────────────────────────
ny_hour       = hour(time, "America/New_York")
is_london_kz  = ny_hour >= 2 and ny_hour < 5
is_london     = ny_hour >= 5 and ny_hour < 8
is_ny_am_kz   = ny_hour >= 7 and ny_hour < 10
is_go_session = is_london_kz or is_london or is_ny_am_kz

bgcolor(show_sessions and is_london_kz                  ? color.new(#1565c0, 90) : na, title="London KZ")
bgcolor(show_sessions and is_ny_am_kz                   ? color.new(#e65100, 90) : na, title="NY AM KZ")
bgcolor(show_sessions and is_london and not is_ny_am_kz ? color.new(#1565c0, 95) : na, title="London")

// ── HTF (4H) DATA ─────────────────────────────────────────────────────────────
[h_open, h_high, h_low, h_close, h_vol] = request.security(syminfo.tickerid, htf, [open, high, low, close, volume], lookahead=barmerge.lookahead_off)
htf_bull = h_close > h_open
htf_bear = h_close < h_open
htf_body = math.abs(h_close - h_open)
htf_atr  = request.security(syminfo.tickerid, htf, ta.atr(14), lookahead=barmerge.lookahead_off)

// ── SWING HIGH / LOW ──────────────────────────────────────────────────────────
ph = ta.pivothigh(high, swing_len, swing_len)
pl = ta.pivotlow(low,  swing_len, swing_len)
var float last_ph = na
var float last_pl = na
if not na(ph)
    last_ph := ph
if not na(pl)
    last_pl := pl

// ── BOS — limited to last 5 labels only ───────────────────────────────────────
bull_bos = not na(last_ph) and ta.crossover(close, last_ph)
bear_bos = not na(last_pl) and ta.crossunder(close, last_pl)

var label[] bos_label_list = array.new_label()

if show_bos and bull_bos
    lbl = label.new(bar_index, low - ta.atr(14) * 0.5, "BOS",
         color=color.new(#00c853,20), textcolor=color.white,
         style=label.style_label_up, size=size.small)
    array.push(bos_label_list, lbl)
    if array.size(bos_label_list) > 5
        label.delete(array.shift(bos_label_list))

if show_bos and bear_bos
    lbl = label.new(bar_index, high + ta.atr(14) * 0.5, "BOS",
         color=color.new(#d50000,20), textcolor=color.white,
         style=label.style_label_down, size=size.small)
    array.push(bos_label_list, lbl)
    if array.size(bos_label_list) > 5
        label.delete(array.shift(bos_label_list))

// ── ORDER BLOCK DETECTION ─────────────────────────────────────────────────────
htf_impulse_up   = htf_bull and htf_body > htf_atr * 0.8 and h_close > h_close[2]
htf_impulse_down = htf_bear and htf_body > htf_atr * 0.8 and h_close < h_close[2]

var float bull_ob_hi    = na
var float bull_ob_lo    = na
var int   bull_ob_start = na
var bool  bull_ob_active = false
var float bear_ob_hi    = na
var float bear_ob_lo    = na
var int   bear_ob_start = na
var bool  bear_ob_active = false

if htf_impulse_up and htf_bear[1]
    bull_ob_hi     := math.max(h_open[1], h_close[1])
    bull_ob_lo     := math.min(h_open[1], h_close[1])
    bull_ob_start  := bar_index
    bull_ob_active := true
if htf_impulse_down and htf_bull[1]
    bear_ob_hi     := math.max(h_open[1], h_close[1])
    bear_ob_lo     := math.min(h_open[1], h_close[1])
    bear_ob_start  := bar_index
    bear_ob_active := true
if bull_ob_active and close < bull_ob_lo - ta.atr(14) * 0.2
    bull_ob_active := false
if bear_ob_active and close > bear_ob_hi + ta.atr(14) * 0.2
    bear_ob_active := false

// ── OB BOXES ─────────────────────────────────────────────────────────────────
var box bull_box = na
var box bear_box = na

if show_ob_zones and bull_ob_active and not na(bull_ob_hi)
    if na(bull_box) or bar_index == bull_ob_start
        if not na(bull_box)
            box.delete(bull_box)
        bull_box := box.new(bull_ob_start - 1, bull_ob_hi, bar_index + 10, bull_ob_lo, border_color=#00c853, border_width=1, bgcolor=bull_ob_col)
    else
        box.set_right(bull_box, bar_index + 10)

if show_ob_zones and bear_ob_active and not na(bear_ob_hi)
    if na(bear_box) or bar_index == bear_ob_start
        if not na(bear_box)
            box.delete(bear_box)
        bear_box := box.new(bear_ob_start - 1, bear_ob_hi, bar_index + 10, bear_ob_lo, border_color=#d50000, border_width=1, bgcolor=bear_ob_col)
    else
        box.set_right(bear_box, bar_index + 10)

plot(bull_ob_active ? bull_ob_hi : na, "Bull OB High", color=color.new(#00c853,40), linewidth=1, style=plot.style_linebr)
plot(bull_ob_active ? bull_ob_lo : na, "Bull OB Low",  color=color.new(#00c853,40), linewidth=1, style=plot.style_linebr)
plot(bear_ob_active ? bear_ob_hi : na, "Bear OB High", color=color.new(#d50000,40), linewidth=1, style=plot.style_linebr)
plot(bear_ob_active ? bear_ob_lo : na, "Bear OB Low",  color=color.new(#d50000,40), linewidth=1, style=plot.style_linebr)

// ── PRICE IN OB ───────────────────────────────────────────────────────────────
in_bull_ob = bull_ob_active and not na(bull_ob_hi) and low <= bull_ob_hi and high >= bull_ob_lo
in_bear_ob = bear_ob_active and not na(bear_ob_hi) and high >= bear_ob_lo and low  <= bear_ob_hi

// ── MSS ENTRY ─────────────────────────────────────────────────────────────────
atr14       = ta.atr(14)
recent_high = ta.highest(high, 10)[1]
recent_low  = ta.lowest(low,   10)[1]
bull_mss    = in_bull_ob and ta.crossover(close, recent_high) and is_go_session
bear_mss    = in_bear_ob and ta.crossunder(close, recent_low)  and is_go_session

if show_entry and bull_mss
    label.new(bar_index, low - atr14 * 1.5, "LONG\nMSS",  color=long_col,  textcolor=color.black, style=label.style_label_up,   size=size.normal)
if show_entry and bear_mss
    label.new(bar_index, high + atr14 * 1.5, "SHORT\nMSS", color=short_col, textcolor=color.white, style=label.style_label_down, size=size.normal)

// ── SL / TP LINES ─────────────────────────────────────────────────────────────
if show_sl_tp and bull_mss and not na(bull_ob_lo)
    sl = bull_ob_lo - atr14 * 0.1
    rr = close - sl
    line.new(bar_index, sl,         bar_index, sl,         extend=extend.right, color=color.new(#ff1744,30), style=line.style_dashed, width=1)
    line.new(bar_index, close+rr,   bar_index, close+rr,   extend=extend.right, color=color.new(#00e676,50), style=line.style_dashed, width=1)
    line.new(bar_index, close+rr*2, bar_index, close+rr*2, extend=extend.right, color=color.new(#00e676,30), style=line.style_dashed, width=1)
    line.new(bar_index, close+rr*3, bar_index, close+rr*3, extend=extend.right, color=color.new(#00e676,10), style=line.style_solid,  width=2)
    label.new(bar_index, sl,         "SL",  color=color.new(#ff1744,0), textcolor=color.white, style=label.style_label_right, size=size.tiny)
    label.new(bar_index, close+rr,   "1R",  color=color.new(#00e676,0), textcolor=color.black, style=label.style_label_right, size=size.tiny)
    label.new(bar_index, close+rr*2, "2R",  color=color.new(#00e676,0), textcolor=color.black, style=label.style_label_right, size=size.tiny)
    label.new(bar_index, close+rr*3, "3R+", color=color.new(#00e676,0), textcolor=color.black, style=label.style_label_right, size=size.tiny)

if show_sl_tp and bear_mss and not na(bear_ob_hi)
    sl = bear_ob_hi + atr14 * 0.1
    rr = sl - close
    line.new(bar_index, sl,         bar_index, sl,         extend=extend.right, color=color.new(#ff1744,30), style=line.style_dashed, width=1)
    line.new(bar_index, close-rr,   bar_index, close-rr,   extend=extend.right, color=color.new(#00e676,50), style=line.style_dashed, width=1)
    line.new(bar_index, close-rr*2, bar_index, close-rr*2, extend=extend.right, color=color.new(#00e676,30), style=line.style_dashed, width=1)
    line.new(bar_index, close-rr*3, bar_index, close-rr*3, extend=extend.right, color=color.new(#00e676,10), style=line.style_solid,  width=2)
    label.new(bar_index, sl,         "SL",  color=color.new(#ff1744,0), textcolor=color.white, style=label.style_label_right, size=size.tiny)
    label.new(bar_index, close-rr,   "1R",  color=color.new(#00e676,0), textcolor=color.black, style=label.style_label_right, size=size.tiny)
    label.new(bar_index, close-rr*2, "2R",  color=color.new(#00e676,0), textcolor=color.black, style=label.style_label_right, size=size.tiny)
    label.new(bar_index, close-rr*3, "3R+", color=color.new(#00e676,0), textcolor=color.black, style=label.style_label_right, size=size.tiny)

// ── INFO TABLE ────────────────────────────────────────────────────────────────
var table t = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black,75), border_color=color.new(color.gray,50), border_width=1)
if show_table and barstate.islast
    table.cell(t, 0, 0, "ICT H4/M5", bgcolor=color.new(#1565c0,40), text_color=color.white, text_size=size.small)
    table.cell(t, 1, 0, "Status",     bgcolor=color.new(#1565c0,40), text_color=color.white, text_size=size.small)
    table.cell(t, 0, 1, "Session",    text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 1, is_london_kz ? "London KZ" : is_ny_am_kz ? "NY AM KZ" : is_london ? "London" : "Off Hours", text_color=is_go_session ? #00e676 : color.gray, text_size=size.tiny)
    table.cell(t, 0, 2, "HTF Bias",   text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 2, htf_bull ? "Bullish (4H)" : htf_bear ? "Bearish (4H)" : "Neutral", text_color=htf_bull ? #00e676 : htf_bear ? #ff1744 : color.gray, text_size=size.tiny)
    table.cell(t, 0, 3, "Bull OB",    text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 3, bull_ob_active ? str.tostring(math.round(bull_ob_hi,5)) + "/" + str.tostring(math.round(bull_ob_lo,5)) : "None", text_color=bull_ob_active ? #00c853 : color.gray, text_size=size.tiny)
    table.cell(t, 0, 4, "Bear OB",    text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 4, bear_ob_active ? str.tostring(math.round(bear_ob_hi,5)) + "/" + str.tostring(math.round(bear_ob_lo,5)) : "None", text_color=bear_ob_active ? #d50000 : color.gray, text_size=size.tiny)
    table.cell(t, 0, 5, "In OB?",     text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 5, in_bull_ob ? "IN BULL OB" : in_bear_ob ? "IN BEAR OB" : "Outside", text_color=in_bull_ob ? #00e676 : in_bear_ob ? #ff1744 : color.gray, text_size=size.tiny)
    table.cell(t, 0, 6, "Signal",     text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 6, bull_mss ? "LONG SIGNAL" : bear_mss ? "SHORT SIGNAL" : "Watching...", text_color=bull_mss ? #00e676 : bear_mss ? #ff1744 : color.gray, text_size=size.tiny)
    table.cell(t, 0, 7, "WR / PF",    text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 7, "75%  PF 2.31", text_color=#ffd600, text_size=size.tiny)
    table.cell(t, 0, 8, "Calmar",     text_color=color.gray, text_size=size.tiny)
    table.cell(t, 1, 8, "140 / +992R", text_color=#ffd600, text_size=size.tiny)

// ── ALERTS ────────────────────────────────────────────────────────────────────
alertcondition(bull_mss,             title="ICT LONG — H4 OB + M5 MSS",  message="LONG: {{ticker}} | H4 OB + M5 MSS in Kill Zone | {{close}}")
alertcondition(bear_mss,             title="ICT SHORT — H4 OB + M5 MSS", message="SHORT: {{ticker}} | H4 OB + M5 MSS in Kill Zone | {{close}}")
alertcondition(bull_mss or bear_mss, title="ICT Signal — Any Direction",  message="ICT ENTRY: {{ticker}} | {{close}} | {{time}}")
alertcondition(in_bull_ob and is_go_session and not in_bull_ob[1], title="ICT WATCH — Entering Bull OB", message="WATCH: {{ticker}} entering Bull H4 OB — wait for M5 MSS")
alertcondition(in_bear_ob and is_go_session and not in_bear_ob[1], title="ICT WATCH — Entering Bear OB", message="WATCH: {{ticker}} entering Bear H4 OB — wait for M5 MSS")
