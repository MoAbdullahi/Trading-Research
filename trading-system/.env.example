# ===========================================================================
# Multi-Agent Trading System — environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env.
# Toggle ALPACA_USE_PAPER between true/false to swap paper <-> live.
# ===========================================================================

# --- US EQUITIES: Alpaca (primary venue, phase 1) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_USE_PAPER=true

# --- FOREX & GOLD: OANDA (phase 4) ---
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
OANDA_ENVIRONMENT=practice          # practice | live

# --- CRYPTO: CCXT exchange (phase 4) ---
CRYPTO_EXCHANGE=binance
CRYPTO_API_KEY=
CRYPTO_SECRET_KEY=

# --- LLM PROVIDERS ---
ANTHROPIC_API_KEY=
REASONING_MODEL=claude-opus-4-8     # deep model for final consensus
FAST_MODEL=claude-haiku-4-5-20251001 # cheap model for parsing / per-agent analysis

# --- PERSISTENCE ---
POSTGRES_DSN=postgresql://user:pass@localhost:5432/trading

# --- GLOBAL RISK PARAMETERS (read by the deterministic gateway) ---
MAX_PER_TRADE_RISK_PCT=2.0          # hard ceiling, must be <= 2.0
MIN_REWARD_TO_RISK=2.0
MAX_CONCURRENT_EXPOSURE_PCT=30.0
MAX_ACCOUNT_DRAWDOWN_PCT=6.0        # daily lock
CONSENSUS_THRESHOLD=3               # >=3 of 5 internal signals must align
ORCHESTRATOR_MAX_TURNS=4            # debate cap; exceed -> FLAT
